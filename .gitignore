# ============================================================
# HESTABIT TRAINING LAUNCHPAD — Root .gitignore
# Covers: Node.js, Next.js, Python, ML/AI, Docker, OS junk
# ============================================================


# ------------------------------------------------------------
# SECRETS & ENVIRONMENT — never commit these
# ------------------------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
secrets/
credentials/


# ------------------------------------------------------------
# NODE.JS / JAVASCRIPT
# ------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.npm/
.yarn/
package-lock.json
# keep yarn.lock if you use yarn — remove this line if so
yarn.lock


# ------------------------------------------------------------
# NEXT.JS
# ------------------------------------------------------------
.next/
.vercel/
out/


# ------------------------------------------------------------
# PYTHON
# ------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
.Python
venv/
env/
.venv/
.env/
pip-log.txt
pip-delete-this-directory.txt
*.egg-info/
dist/
build/
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/


# ------------------------------------------------------------
# JUPYTER NOTEBOOKS
# ------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb_checkpoints


# ------------------------------------------------------------
# ML / AI MODEL ARTIFACTS — large binaries, not for git
# ------------------------------------------------------------

# Trained model weights & checkpoints
*.pkl
*.pickle
*.pt
*.pth
*.onnx
*.h5
*.hdf5
*.safetensors
*.gguf
*.ggml
*.bin          # catches largefile.bin and model binaries
checkpoints/
lora_adapter/
exports/
models/weights/
output/
outputs/
quick_output/

# Quantised models (Week 8 — these are huge)
quantized/
gguf_models/
llama.cpp/

# FAISS / vector indexes
*.faiss
*.index
*_meta.pkl
*_vectors.pkl

# SQLite runtime databases (generated at runtime)
*.db
*.sqlite
*.sqlite3

# Training logs & run artifacts
training_logs/*.json
logs/*.log
logs/*_trace.json
wandb/
mlruns/
runs/

# Large datasets (>1MB CSVs, processed data)
# Keep raw sample data — ignore large processed outputs
src/data/processed/
data/processed/
data/versions/
data/customers-100000.csv
data/people-100000.csv


# ------------------------------------------------------------
# DOCKER & DEVOPS
# ------------------------------------------------------------
.docker/
docker-compose.override.yml


# ------------------------------------------------------------
# DEMO / MEDIA FILES — too large for git
# ------------------------------------------------------------
*.webm
*.mp4
*.mov
*.avi
# Keep screenshots (PNG/JPG) — they document the work
# If repo gets too large, move screenshots to a release asset
# *.png
# *.jpg


# ------------------------------------------------------------
# LOGS (runtime generated — not source)
# ------------------------------------------------------------
*.log
logs/
cron.log
validate.log
app.log
pm2-*.log


# ------------------------------------------------------------
# BUILD & CACHE DIRECTORIES
# ------------------------------------------------------------
dist/
build/
.cache/
.parcel-cache/
.turbo/


# ------------------------------------------------------------
# OS GENERATED JUNK
# ------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V8
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini


# ------------------------------------------------------------
# EDITOR & IDE
# ------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.history/


# ------------------------------------------------------------
# RUNTIME DATA DIRS (Week 9 Nexus AI generates these)
# ------------------------------------------------------------
memory/
data/agent_memory.db
data/faiss_index.bin
data/tasks.db
data/results.db
data/agent_registry.json
data/execution_graph.json
nexus_ai/memory/
