    {
      "name": "5 — Request Tracing",
      "item": [
        {
          "name": "Custom Correlation ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Correlation ID echoed back', () => {",
                  "    const reqId = pm.response.headers.get('X-Request-ID');",
                  "    pm.expect(reqId).to.exist;",
                  "    console.log('Correlation ID:', reqId);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "X-Request-ID", "value": "my-custom-trace-001" }
            ],
            "url": { "raw": "{{BASE_URL}}/health", "host": ["{{BASE_URL}}"], "path": ["health"] },
            "description": "Send a custom X-Request-ID and verify it's reflected in the response."
          }
        },
        {
          "name": "Trace through User Create",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Request ID present', () => {",
                  "    pm.response.to.have.header('X-Request-ID');",
                  "});",
                  "console.log('Trace ID:', pm.response.headers.get('X-Request-ID'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Request-ID", "value": "trace-user-create-001" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Traced User\",\n  \"email\": \"traced@example.com\",\n  \"password\": \"TracePass123!\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{BASE_URL}}/api/users", "host": ["{{BASE_URL}}"], "path": ["api", "users"] },
