                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{BASE_URL}}/api-docs.json", "host": ["{{BASE_URL}}"], "path": ["api-docs.json"] },
            "description": "Returns the full OpenAPI 3.0 specification as JSON."
          }
