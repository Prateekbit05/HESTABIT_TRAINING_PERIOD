{
  "info": {
    "_postman_id": "day5-job-queues-logging-api-docs",
    "name": "Day 5 - Job Queues, Logging & API Docs",
    "description": "Complete Postman collection for Day 5: Job Queues (Bull), Winston Logging, Request Tracing, Swagger API Docs, and PM2 process management.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": "1.0.0"
  },
  "variable": [
    { "key": "BASE_URL", "value": "http://localhost:3000", "type": "default" },
    { "key": "userId",    "value": "", "type": "default" },
    { "key": "productId", "value": "", "type": "default" },
    { "key": "emailJobId",  "value": "", "type": "default" },
    { "key": "reportJobId", "value": "", "type": "default" }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "exec": [
          "// Inject a unique correlation ID into every request",
          "pm.request.headers.add({",
          "    key: 'X-Request-ID',",
          "    value: 'postman-' + Date.now()",
          "});"
        ],
        "type": "text/javascript"
      }
    },
    {
      "listen": "test",
      "script": {
        "exec": [
          "// Global: response time under 2s",
          "pm.test('Response time < 2000ms', () => {",
          "    pm.expect(pm.response.responseTime).to.be.below(2000);",
          "});",
          "",
          "// Global: correlation ID present in response",
          "pm.test('X-Request-ID header present', () => {",
          "    pm.response.to.have.header('X-Request-ID');",
          "});"
        ],
        "type": "text/javascript"
      }
    }
  ],
  "item": [
    {
      "name": "0 — System",
      "item": [
        {
          "name": "Health Check",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('status is OK', () => {",
                  "    pm.expect(pm.response.json().status).to.eql('OK');",
                  "});",
                  "pm.test('Has uptime', () => {",
                  "    pm.expect(pm.response.json()).to.have.property('uptime');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{BASE_URL}}/health", "host": ["{{BASE_URL}}"], "path": ["health"] },
            "description": "Returns server status, uptime, and requestId. Check X-Request-ID in response headers."
          }
        },
        {
          "name": "Get Swagger JSON Spec",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Is valid OpenAPI spec', () => {",
